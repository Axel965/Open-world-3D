let jLV={x:0,y:0},jLID=null,jLA=false,jRV={x:0,y:0},jRID=null,jRA=false;
const JR=30;
function jDelta(t,z){const r=z.getBoundingClientRect();let dx=t.clientX-(r.left+r.width/2),dy=t.clientY-(r.top+r.height/2);const l=Math.sqrt(dx*dx+dy*dy);if(l>JR){dx=dx/l*JR;dy=dy/l*JR;}return{dx,dy,nx:dx/JR,ny:dy/JR};}
function setK(k,dx,dy){k.style.left=`calc(50% + ${dx}px - 17px)`;k.style.top=`calc(50% + ${dy}px - 17px)`;}
