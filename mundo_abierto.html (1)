function updNPCs(dt){
  if(!gameOn)return;
  npcs.forEach((n,ni)=>{
    if(n.dead){n.dT-=dt;if(n.dT<=0)n.mesh.visible=false;return;}
    const dx=P.x-n.x,dz=P.z-n.z,dp=Math.sqrt(dx*dx+dz*dz);
    n.stT=Math.max(0,n.stT-dt);n.atkT=Math.max(0,(n.atkT||0)-dt);
    if(G.petBonus.auto&&n.hostile&&dp<6){n.hp-=.5*dt*60;if(n.hp<=0){killNPC(n);return;}}
    if(n.hostile){
      if(dp<18)n.state='chase';else if(n.state==='chase'&&dp>24){n.state='patrol';n.stT=2;}
      if(n.state==='patrol'){if(n.stT<=0){n.pAng+=(Math.random()-.5)*2;n.stT=rng(1.5,3);}const s=.013*dt*60;const nx=n.x+Math.cos(n.pAng)*s,nz=n.z+Math.sin(n.pAng)*s;if(!colB(nx,n.z))n.x=nx;else n.pAng+=1.2;if(!colB(n.x,nz))n.z=nz;else n.pAng+=1.2;}
      else{const s=.02*dt*60,a=Math.atan2(dz,dx)+(Math.random()-.5)*.3;const nx=n.x+Math.cos(a)*s,nz=n.z+Math.sin(a)*s;if(!colB(nx,n.z))n.x=nx;if(!colB(n.x,nz))n.z=nz;if(dp<1.4&&n.atkT<=0){P.hp=Math.max(0,P.hp-12);n.atkT=1.2;updH();damageFX();if(P.hp<=0)respawn();}}
    } else {
      n.chatTimer=Math.max(0,(n.chatTimer||0)-dt);
      if(n.stT<=0){if(Math.random()<.2&&n.group>=0){const gm=npcs.filter((o,oi)=>oi!==ni&&!o.dead&&!o.hostile&&o.group===n.group);if(gm.length>0){const mate=gm[Math.floor(Math.random()*gm.length)];const toX=mate.x-n.x,toZ=mate.z-n.z;const d2=Math.sqrt(toX*toX+toZ*toZ);if(d2>3){n.ang=Math.atan2(toZ,toX);n.state='wander';}else{n.state='idle';n.chatTimer=rng(2,5);}}}else{n.state=n.state==='wander'?'idle':'wander';}n.stT=rng(1.5,4);if(n.state==='wander')n.ang=rng(0,6.28);}
      if(n.state==='wander'&&n.chatTimer<=0){const s=.007*dt*60;const nx=n.x+Math.cos(n.ang)*s,nz=n.z+Math.sin(n.ang)*s;if(!colB(nx,n.z))n.x=nx;else n.ang+=1.2;if(!colB(n.x,nz))n.z=nz;else n.ang+=1.2;}
    }
    n.mesh.position.set(n.x,.3,n.z);if(n.hostile)n.mesh.rotation.y=Math.atan2(P.x-n.x,P.z-n.z);else n.mesh.rotation.y=n.ang;
  });
}
