jRZ.addEventListener('touchstart',e=>{e.preventDefault();const t=e.changedTouches[0];jRID=t.identifier;jRA=true;const d=jDelta(t,jRZ);setK(jRK,d.dx,d.dy);jRV={x:d.nx,y:d.ny};},{passive:false});
document.addEventListener('touchmove',e=>{for(const t of e.changedTouches){if(t.identifier===jLID&&jLA){const d=jDelta(t,jLZ);setK(jLK,d.dx,d.dy);jLV={x:d.nx,y:d.ny};}if(t.identifier===jRID&&jRA){const d=jDelta(t,jRZ);setK(jRK,d.dx,d.dy);jRV={x:d.nx,y:d.ny};}}},{passive:false});
document.addEventListener('touchend',e=>{for(const t of e.changedTouches){if(t.identifier===jLID){jLA=false;jLV={x:0,y:0};rstK(jLK);}if(t.identifier===jRID){jRA=false;jRV={x:0,y:0};rstK(jRK);}}});

function colB(nx,nz){const M2=.9;return bldgs.some(b=>nx>b.cx-b.w/2-M2&&nx<b.cx+b.w/2+M2&&nz>b.cz-b.d/2-M2&&nz<b.cz+b.d/2+M2);}

function moveP(dt){
  if(!gameOn||panelOpen()||G.inCar)return;
  if(jRA){camH-=jRV.x*.055;camV=clamp(camV+jRV.y*.04,-.5,.5);}
  let fwd=0,str=0;
  if(keys['KeyW']||keys['ArrowUp'])   fwd= 1;
  if(keys['KeyS']||keys['ArrowDown']) fwd=-1;
  if(keys['KeyA']||keys['ArrowLeft']) str=-1;
  if(keys['KeyD']||keys['ArrowRight'])str= 1;
  if(jLA){if(Math.abs(jLV.y)>.06)fwd=-jLV.y;if(Math.abs(jLV.x)>.06)str=jLV.x;}
  // VERIFIED: camera.rotation.y=camH → fwd=(-sin,-cos), rgt=(+cos,-sin)
  const fX=-Math.sin(camH),fZ=-Math.cos(camH);
  const rX= Math.cos(camH),rZ=-Math.sin(camH);
  const moving=fwd!==0||str!==0;
  if(moving){
    const spd=P.spd*(G.petBonus.sm||1)*dt*60;
    let mx=fX*fwd+rX*str,mz=fZ*fwd+rZ*str;
    const ml=Math.sqrt(mx*mx+mz*mz)||1;mx=mx/ml*spd;mz=mz/ml*spd;
    const nx=P.x+mx,nz=P.z+mz;
    if(!colB(nx,P.z))P.x=clamp(nx,-108,108);
    if(!colB(P.x,nz))P.z=clamp(nz,-108,108);
    walkBob+=dt*8;
    pLL.rotation.x= Math.sin(walkBob)*.5;pRL.rotation.x=-Math.sin(walkBob)*.5;
    pLA.rotation.x=-Math.sin(walkBob)*.38;pRA.rotation.x= Math.sin(walkBob)*.38;
    pBody.position.y=.9+Math.abs(Math.sin(walkBob))*.035;
    P.ang=Math.atan2(-(fX*fwd+rX*str),-(fZ*fwd+rZ*str))+Math.PI;
  }
  PG.position.set(P.x,0,P.z);PG.rotation.y=P.ang;
  const eyeH=1.65;
  if(camMode===0){camera.position.set(P.x,eyeH,P.z);camera.rotation.y=camH;camera.rotation.x=camV;}
  else if(camMode===1){const tx=P.x+Math.sin(camH)*9,ty=eyeH+5,tz=P.z+Math.cos(camH)*9;camera.position.lerp(new THREE.Vector3(tx,ty,tz),.15);camera.lookAt(P.x,eyeH,P.z);}
  else{const tx=P.x-Math.sin(camH)*8,ty=eyeH+4,tz=P.z-Math.cos(camH)*8;camera.position.lerp(new THREE.Vector3(tx,ty,tz),.15);camera.lookAt(P.x,eyeH,P.z);}
  if(!camera.userData.arm){const a=new THREE.Mesh(BG(.11,.11,.42),M(0xffcc99));a.position.set(.26,-.2,-.4);camera.add(a);camera.userData.arm=a;}
  camera.userData.arm.visible=(camMode===0&&!G.inCar);
}

function updCars(dt){
  if(!gameOn)return;
  cars.forEach(c=>{
    if(c.dead)return;c.hitCD=Math.max(0,c.hitCD-dt);
    if(c.isAI&&!c.isPlayer){
      const spd=5.5*dt;
      if(c.roadAxis==='x'){c.z+=c.dir*spd;if(c.z>c.routeMax){c.z=c.routeMax;c.dir=-1;}if(c.z<c.routeMin){c.z=c.routeMin;c.dir=1;}c.angle=c.dir>0?0:Math.PI;}
      else{c.x+=c.dir*spd;if(c.x>c.routeMax){c.x=c.routeMax;c.dir=-1;}if(c.x<c.routeMin){c.x=c.routeMin;c.dir=1;}c.angle=c.dir>0?-Math.PI/2:Math.PI/2;}
      c.mesh.position.set(c.x,0,c.z);c.mesh.rotation.y=c.angle;c.mesh.userData.wheels.forEach(w=>w.rotation.x+=spd*1.3);
    }
    if(c.isPlayer){
      let acc=0,turn=0;
      if(keys['KeyW']||keys['ArrowUp'])   acc= 1;if(keys['KeyS']||keys['ArrowDown']) acc=-1;
      if(keys['KeyA']||keys['ArrowLeft']) turn= 1;if(keys['KeyD']||keys['ArrowRight'])turn=-1;
      if(jLA){if(Math.abs(jLV.y)>.06)acc=-jLV.y;if(Math.abs(jLV.x)>.06)turn=-jLV.x;}
      const maxS=22,accel=16;
      if(acc>0)c.speed=Math.min(maxS,c.speed+accel*dt);else if(acc<0)c.speed=Math.max(-maxS*.5,c.speed-accel*dt);else c.speed*=.90;
      const turnRate=2.2*dt*(1-Math.abs(c.speed)/maxS*.5+.3);if(Math.abs(c.speed)>.3){c.steer=clamp(c.steer+turn*turnRate,-1,1);}c.steer*=.78;
      if(Math.abs(c.speed)>.3)c.angle+=c.steer*Math.sign(c.speed)*.04*Math.abs(c.speed);
      const cfX=Math.sin(c.angle),cfZ=Math.cos(c.angle);
      const tVX=cfX*c.speed*dt,tVZ=cfZ*c.speed*dt;const grip=.78;
      c.velX=c.velX*(1-grip)+tVX*grip;c.velZ=c.velZ*(1-grip)+tVZ*grip;
      const nx=c.x+c.velX,nz=c.z+c.velZ;
      if(!colB(nx,c.z))c.x=clamp(nx,-108,108);else{c.speed*=-.35;c.velX*=-.35;if(c.hitCD<=0){c.hp-=10;c.hitCD=.55;damageFX();}}
      if(!colB(c.x,nz))c.z=clamp(nz,-108,108);else{c.speed*=-.35;c.velZ*=-.35;if(c.hitCD<=0){c.hp-=10;c.hitCD=.55;damageFX();}}
      G.kmDriven+=Math.abs(c.speed)*dt;
      c.mesh.position.set(c.x,0,c.z);c.mesh.rotation.y=c.angle;c.mesh.userData.wheels.forEach(w=>w.rotation.x+=c.speed*dt*1.3);
      camH=-c.angle;const bx=c.x+Math.sin(c.angle)*10,bz=c.z+Math.cos(c.angle)*10;
      camera.position.lerp(new THREE.Vector3(bx,5.6,bz),.12);camera.lookAt(c.x,1,c.z);
      document.getElementById('cSpd').textContent=Math.abs(c.speed*3.6).toFixed(0);document.getElementById('cHp').textContent=c.hp;
    }
    if(c.isAI&&!G.inCar&&c.hitCD<=0){if(Math.hypot(P.x-c.x,P.z-c.z)<2.2){P.hp=Math.max(0,P.hp-18);c.hitCD=.9;updH();damageFX();showMsg('🚗 ¡Atropellado! −18HP');if(P.hp<=0)respawn();}}
    npcs.forEach(n=>{if(n.dead||(!c.isAI&&!c.isPlayer))return;if(Math.hypot(n.x-c.x,n.z-c.z)<2.1){n.hp-=80;if(n.hp<=0){killNPC(n);showMsg(`🚗 ¡${n.name} atropellado!`);}}});
    if(c.hp<=0&&!c.dead){c.dead=true;c.mesh.traverse(ch=>{if(ch.isMesh)ch.material=M(0x111111);});showMsg('💥 ¡AUTO DESTRUIDO!');if(c.isPlayer)exitCar();}
  });
}
