  const g=new THREE.Group();const col=color||CARCOLS[Math.floor(rng(0,CARCOLS.length))];
  const dc=new THREE.Color(col).multiplyScalar(.65).getHex();
  const body=new THREE.Mesh(BG(2.1,.82,4.4),M(col));body.position.y=.62;g.add(body);
  const cab=new THREE.Mesh(BG(1.78,.62,2.25),M(dc));cab.position.set(0,1.22,.15);g.add(cab);
  const fBump=new THREE.Mesh(BG(2.1,.22,.3),M(dc));fBump.position.set(0,.32,2.25);g.add(fBump);
  const rBump=fBump.clone();rBump.position.z=-2.25;g.add(rBump);
  const glass=new THREE.Mesh(BG(1.64,.48,.1),MB(0x88aabb));glass.position.set(0,1.22,1.3);g.add(glass);
  const hood=new THREE.Mesh(BG(2.05,.12,1.6),M(new THREE.Color(col).multiplyScalar(.9).getHex()));hood.position.set(0,.88,1.5);g.add(hood);
  const whlG=new THREE.CylinderGeometry(.38,.38,.3,12);const whlM=M(0x111111);const hubM=MB(0x777788);const wheels=[];
  [[.98,.38,1.45],[-.98,.38,1.45],[.98,.38,-1.45],[-.98,.38,-1.45]].forEach(([wx,wy,wz])=>{const w=new THREE.Mesh(whlG,whlM);w.rotation.z=Math.PI/2;w.position.set(wx,wy,wz);g.add(w);const hub=new THREE.Mesh(new THREE.CircleGeometry(.28,8),hubM);hub.rotation.y=wx>0?-Math.PI/2:Math.PI/2;hub.position.set(wx+(wx>0?.16:-.16),wy,wz);g.add(hub);wheels.push(w);});
  const hlM=MB(0xffffcc);[-0.65,.65].forEach(hx=>{const hl=new THREE.Mesh(new THREE.CircleGeometry(.14,8),hlM);hl.position.set(hx,.66,2.23);g.add(hl);});
  const tlM=MB(0xff2200);[-0.65,.65].forEach(tx=>{const tl=new THREE.Mesh(new THREE.CircleGeometry(.13,8),tlM);tl.position.set(tx,.66,-2.23);tl.rotation.y=Math.PI;g.add(tl);});
  g.userData.wheels=wheels;return g;
}
