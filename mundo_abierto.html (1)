const diaM=MB(0x00eeff),coinM2=MB(0xffcc00);
function spawnPU(x,z,type,val){const g=new THREE.Group();if(type==='diamond')g.add(new THREE.Mesh(new THREE.OctahedronGeometry(.38,0),diaM));else g.add(new THREE.Mesh(CG(.3,.1,10),coinM2));g.position.set(x,.5,z);scene.add(g);pickups.push({mesh:g,x,z,type,val:val||0,alive:true,bobT:rng(0,6.28)});}
for(let i=0;i<10;i++)spawnPU(rng(-90,90),rng(-90,90),'diamond');
for(let i=0;i<18;i++)spawnPU(rng(-90,90),rng(-90,90),'money',Math.floor(rng(50,260)));
function updPU(dt){puT-=dt;if(puT<=0){puT=18+rng(0,14);spawnPU(rng(-90,90),rng(-90,90),Math.random()<.25?'diamond':'money',Math.floor(rng(60,320)));}pickups.forEach((p,i)=>{if(!p.alive){pickups.splice(i,1);return;}p.bobT+=dt*2;p.mesh.position.y=.5+Math.sin(p.bobT)*.2;p.mesh.rotation.y+=dt*1.3;if(Math.hypot(P.x-p.x,P.z-p.z)<1.1){p.alive=false;scene.remove(p.mesh);const mm=G.petBonus.mm||1;G.xp+=15*(G.petBonus.xpm||1);checkLevel();if(p.type==='diamond'){G.diamonds++;G.money+=Math.floor(500*mm);updH();showMsg(`💎 +$${Math.floor(500*mm)}`);}else{G.money+=Math.floor(p.val*mm);updH();showMsg(`💵 +$${Math.floor(p.val*mm)}`);}}});}

function shoot(){if(!gameOn||G.inCar||shootCD>0)return;if(!G.weapon){showMsg('❌ Entra a una Armería para comprar un arma.');return;}document.getElementById('wpn').classList.add('fire');setTimeout(()=>document.getElementById('wpn').classList.remove('fire'),110);shootCD=.27;const fX=-Math.sin(camH),fZ=-Math.cos(camH);const fwd3=new THREE.Vector3(fX,0,fZ);let best=null,bd=Infinity;npcs.forEach(n=>{if(n.dead)return;const dx=n.x-P.x,dz=n.z-P.z,d=Math.sqrt(dx*dx+dz*dz);if(d>26)return;if(fwd3.dot(new THREE.Vector3(dx,0,dz).normalize())>.88&&d<bd){bd=d;best=n;}});if(best){const base={Pistola:28,Escopeta:70,Rifle:100,Motosierra:52,Lanzamisiles:150}[G.weapon]||28;const dmg=Math.floor(base*(G.petBonus.dm||1)*(G.skin==='ninja'?1.2:1));best.hp-=dmg;G.xp+=20*(G.petBonus.xpm||1);checkLevel();if(best.hp<=0)killNPC(best);else if(!best.hostile){best.hostile=true;best.state='chase';addWanted(1);showMsg(`⚠️ ¡${best.name} enfurecido!`);}else showMsg(`💥 ${best.name} −${dmg}HP`);}else showMsg(`${G.wIcon} ¡Fuego!`);}

function addWanted(n){G.wanted=Math.min(5,G.wanted+n);wantedTimer=15;for(let i=1;i<=5;i++)document.getElementById('ws'+i).className='wS'+(i<=G.wanted?' on':'');document.getElementById('wanted').style.display='flex';if(G.wanted>=3)showMsg('⚠️ ¡Buscado! Policía en camino.');}
function tickWanted(dt){if(!G.wanted)return;wantedTimer-=dt;if(wantedTimer<=0){G.wanted=Math.max(0,G.wanted-1);wantedTimer=10;for(let i=1;i<=5;i++)document.getElementById('ws'+i).className='wS'+(i<=G.wanted?' on':'');if(!G.wanted)document.getElementById('wanted').style.display='none';}}
function checkLevel(){const xpN=G.level*500;if(G.xp>=xpN){G.level++;G.xp-=xpN;P.mhp+=10;P.hp=Math.min(P.hp+15,P.mhp);showMsg(`⭐ ¡NIVEL ${G.level}!\n+10 HP máximo`);updH();}}
