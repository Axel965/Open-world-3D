function updDN(){const t=G.dayMin/1440;let sc,si,ai,fc;
  if(t<.2){sc=0x020208;fc=0x030310;si=0;ai=.15;}else if(t<.28){const f=(t-.2)/.08;const a=new THREE.Color(0x020208),b2=new THREE.Color(0xff5500);sc=a.lerpColors(a,b2,f).getHex();fc=sc;si=f*.75;ai=.15+f*.35;}else if(t<.35){const f=(t-.28)/.07;const a=new THREE.Color(0xff5500),b2=new THREE.Color(0x6699cc);sc=a.lerpColors(a,b2,f).getHex();fc=new THREE.Color(0x88aacc).getHex();si=.75+f*.5;ai=.5+f*.2;}else if(t<.68){sc=0x4488cc;fc=0x88aacc;si=1.25;ai=.7;}else if(t<.76){const f=(t-.68)/.08;const a=new THREE.Color(0x4488cc),b2=new THREE.Color(0xff4400);sc=a.lerpColors(a,b2,f).getHex();fc=sc;si=1.25-f*1.25;ai=.7-f*.4;}else if(t<.85){const f=(t-.76)/.09;const a=new THREE.Color(0xff4400),b2=new THREE.Color(0x020208);sc=a.lerpColors(a,b2,f).getHex();fc=sc;si=0;ai=.3-f*.15;}else{sc=0x020208;fc=0x030310;si=0;ai=.15;}
  renderer.setClearColor(sc);scene.fog.color.set(fc);sunL.intensity=si;ambL.intensity=ai;hemiL.intensity=ai*.55;fillL.intensity=ai*.25;
  sunL.position.set(Math.cos(t*Math.PI*2)*85,Math.sin(t*Math.PI*2)*85,30);
  const night=t<.25||t>.78;scene.traverse(o=>{if(o.userData&&o.userData.blink)o.material=MB(night?0xff2200:0x111111);});
  if(water)water.material=MB(night?0x112244:0x2266cc);}

