const MS=120/240;
function drawMM(){if(!gameOn)return;mmCtx.fillStyle='#030308';mmCtx.fillRect(0,0,120,120);mmCtx.fillStyle='rgba(100,80,60,.3)';mmCtx.fillRect((70+120)*MS,(70+120)*MS,50,50);mmCtx.fillStyle='rgba(40,40,30,.3)';mmCtx.fillRect(0,0,60,60);mmCtx.fillStyle='rgba(40,30,30,.3)';mmCtx.fillRect(60,0,60,60);mmCtx.fillStyle='#28283a';ROAD_VALS.forEach(rv=>{mmCtx.fillRect(0,(rv+120)*MS-1.5,120,5*MS);mmCtx.fillRect((rv+120)*MS-1.5,0,5*MS,120);});bldgs.forEach(b=>{const c=new THREE.Color(b.bd.wall);mmCtx.fillStyle=`rgb(${c.r*65|0},${c.g*65|0},${c.b*65|0})`;mmCtx.fillRect((b.cx+120)*MS-b.w*MS/2,(b.cz+120)*MS-b.d*MS/2,b.w*MS,b.d*MS);});pickups.forEach(p=>{if(!p.alive)return;mmCtx.fillStyle=p.type==='diamond'?'#0ef':'#fc0';mmCtx.beginPath();mmCtx.arc((p.x+120)*MS,(p.z+120)*MS,1.8,0,Math.PI*2);mmCtx.fill();});cars.forEach(c=>{if(c.dead)return;mmCtx.fillStyle=c.isPlayer?'#ff0':'#fa6';mmCtx.fillRect((c.x+120)*MS-1.8,(c.z+120)*MS-1.8,3.6,3.6);});npcs.forEach(n=>{if(n.dead)return;mmCtx.fillStyle=n.hostile?'#f33':'#3c6';mmCtx.beginPath();mmCtx.arc((n.x+120)*MS,(n.z+120)*MS,1.4,0,Math.PI*2);mmCtx.fill();});const px=(P.x+120)*MS,pz=(P.z+120)*MS;mmCtx.fillStyle='#4af';mmCtx.beginPath();mmCtx.arc(px,pz,3.2,0,Math.PI*2);mmCtx.fill();mmCtx.strokeStyle='#fff';mmCtx.lineWidth=.9;mmCtx.stroke();mmCtx.strokeStyle='rgba(255,255,255,.45)';mmCtx.lineWidth=1.3;mmCtx.beginPath();mmCtx.moveTo(px,pz);mmCtx.lineTo(px-Math.sin(camH)*7,pz-Math.cos(camH)*7);mmCtx.stroke();}

