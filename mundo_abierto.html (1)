function colBldg(){let b=null,bd=Infinity;bldgs.forEach(bl=>{const d=Math.sqrt((P.x-bl.cx)**2+(P.z-bl.cz)**2);if(d<bl.w*.8&&d<bd){bd=d;b=bl;}});return b;}
function nearNPC(){let b=null,bd=3.2;npcs.forEach(n=>{if(n.dead)return;const d=Math.hypot(P.x-n.x,P.z-n.z);if(d<bd){bd=d;b=n;}});return b;}
function updPrompt(){if(!gameOn)return;const el=document.getElementById('prompt');if(G.inCar){el.textContent='[E] Salir del auto';el.style.display='block';return;}const nc=getNearCar();if(nc&&!nc.dead){el.textContent='[E] 🚗 Entrar al auto';el.style.display='block';return;}if(G.petBonus.radar&&npcs.some(x=>!x.dead&&x.hostile&&Math.hypot(P.x-x.x,P.z-x.z)<12)){el.textContent='🐕 ¡Enemigo cerca!';el.style.display='block';return;}const n=nearNPC(),b=colBldg();if(n&&!n.hostile){el.textContent=`[E] Hablar: ${n.name}`;el.style.display='block';}else if(n&&n.hostile){el.textContent=`⚠ ${n.name} ${Math.ceil(n.hp)}HP`;el.style.display='block';}else if(b){el.textContent=`[E] Entrar: ${b.name}`;el.style.display='block';}else el.style.display='none';const style=getZoneStyle(P.x,P.z);const zoneNames={downtown:'Centro — Rascacielos',industrial:'Zona Industrial',residential:'Zona Residencial',beach:'Playa & Casino',suburban:'Zona Suburbana'};document.getElementById('zone').textContent=zoneNames[style]||'';}
function interact(){if(!gameOn)return;if(G.inCar){exitCar();return;}const nc=getNearCar();if(nc&&!nc.dead){enterCar(nc);return;}const n=nearNPC();if(n&&!n.dead&&!n.hostile){openNPC(n);return;}const b=colBldg();if(b)openInterior(b);}

