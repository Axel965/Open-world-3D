function copyRoomCode(){
  if(!MP.roomCode){showMsg('❌ No hay sala activa');return;}
  try{navigator.clipboard.writeText(MP.roomCode);showMsg(`📋 Código copiado: ${MP.roomCode}`);}
  catch(e){showMsg(`📡 Código de sala: ${MP.roomCode}`);}
}

function inviteFriend(){
  if(!MP.roomCode){showMsg('❌ No hay sala activa');return;}
  const msg=`🎮 ¡Únete a mi partida en OpenWorld!\nCódigo: ${MP.roomCode}`;
  try{navigator.share?navigator.share({title:'OpenWorld GTA',text:msg}):navigator.clipboard.writeText(MP.roomCode);}
  catch(e){}
  showMsg(`📡 Código: ${MP.roomCode}\nCompártelo con tus amigos`);
}

function disconnectMP(){
  if(MP.syncInt){clearInterval(MP.syncInt);MP.syncInt=null;}
  Object.entries(MP.conns).forEach(([,c])=>{try{c.close();}catch(e){}});
  MP.conns={};
  Object.values(MP.others).forEach(op=>{try{scene.remove(op.mesh);}catch(e){}});
  MP.others={};
  if(MP.peer){try{MP.peer.destroy();}catch(e){} MP.peer=null;}
  MP.connected=false;MP.roomCode=null;MP.myId=null;
  updMPHud();
  showMsg('🔌 Desconectado de la sala');
}

// Interpolate remote players each frame
function updRemotes(dt){
  Object.entries(MP.others).forEach(([uid,op])=>{
    op.x+=(op.tx-op.x)*.22; op.z+=(op.tz-op.z)*.22;
    let da=op.tang-op.ang;if(da>Math.PI)da-=Math.PI*2;if(da<-Math.PI)da+=Math.PI*2;op.ang+=da*.22;
    op.wb+=dt*8;
    op.mesh.position.set(op.x,0,op.z);op.mesh.rotation.y=op.ang;
    const moving=Math.hypot(op.tx-op.x,op.tz-op.z)>.05;
    if(moving&&op.mesh.children[2]){op.mesh.children[2].rotation.x=Math.sin(op.wb)*.5;op.mesh.children[3].rotation.x=-Math.sin(op.wb)*.5;}
    if(op.nMesh)op.nMesh.rotation.y=-op.ang+camH;
    if(Date.now()-op.last>10000)removeRemote(uid);
  });
}

// Broadcast to all peers
function broadcast(data,skip){
  Object.entries(MP.conns).forEach(([id,conn])=>{
    if(id===skip)return;try{if(conn.open)conn.send(data);}catch(e){}
  });
}

// Handle incoming data
function onMsg(data,fromId){
  try{
    const d=typeof data==='string'?JSON.parse(data):data;
    if(d.t==='pos'){
      if(!MP.others[fromId]){
        MP.others[fromId]=buildRemote(fromId,d.col||0xff4422,d.name||fromId.slice(0,8));
        updMPHud();showMsg(`👥 ${d.name||'Jugador'} se unió`);
        addKF(`👥 ${d.name||'Jugador'} entró`);
      }
      const op=MP.others[fromId];op.tx=d.x;op.tz=d.z;op.tang=d.a;op.last=Date.now();
    } else if(d.t==='chat'){
      addKF(`💬 ${d.name}: ${d.msg}`);
    } else if(d.t==='join'){
      if(MP.isHost){
        broadcast({t:'peer',id:fromId,name:d.name,col:d.col},fromId);
        Object.entries(MP.others).forEach(([pid,op])=>{
          try{if(MP.conns[fromId]?.open)MP.conns[fromId].send({t:'peer',id:pid,name:op.name,col:op.color||0xff4422});}catch(e){}
        });
      }
    } else if(d.t==='peer'){
      if(d.id!==MP.myId&&!MP.conns[d.id])connectTo(d.id);
    }
  }catch(e){}
}

// Setup a connection
function setupConn(conn){
  conn.on('open',()=>{
    MP.conns[conn.peer]=conn;
    conn.send({t:'join',name:myMPName,col:myMPColor,x:P.x,z:P.z,a:P.ang});
    updMPHud();
    mpStatus(`🟢 Conectado · ${mpCount()} jugador(es)`,'#44ff88');
  });
  conn.on('data',d=>onMsg(d,conn.peer));
  conn.on('close',()=>{
    const name=MP.others[conn.peer]?.name||conn.peer.slice(0,8);
    removeRemote(conn.peer);addKF(`🚪 ${name} salió`);
    mpStatus(`⚪ ${mpCount()} jugador(es) conectados`);
  });
  conn.on('error',()=>removeRemote(conn.peer));
}
function connectTo(id){if(!MP.conns[id]){const c=MP.peer.connect(id,{reliable:false,serialization:'json'});setupConn(c);}}

// Start position sync loop
function startSync(){
  if(MP.syncInt)clearInterval(MP.syncInt);
  MP.syncInt=setInterval(()=>{
    if(!MP.connected)return;
    broadcast({t:'pos',x:Math.round(P.x*100)/100,z:Math.round(P.z*100)/100,a:Math.round(P.ang*100)/100,name:myMPName,col:myMPColor});
  },80);
}

// Generate short room code
function genCode(){
  const c='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  return 'OW'+Array.from({length:5},()=>c[Math.floor(Math.random()*c.length)]).join('');
}

// HOST
function hostRoom(){
  if(MP.peer){MP.peer.destroy();MP.peer=null;}
  const code=genCode();
  mpStatus('⏳ Creando sala...');
  MP.peer=new Peer(code,{debug:0});
  MP.isHost=true;
  MP.peer.on('open',id=>{
    MP.myId=id;MP.connected=true;MP.roomCode=code;
    mpStatus(`📡 Sala: <strong style="color:var(--g);letter-spacing:2px">${code}</strong> — compártela`,'#44ff88');
    try{navigator.clipboard.writeText(code);}catch(e){}
    showMsg(`📡 ¡Sala creada!
Código: ${code}
(copiado al portapapeles)

Comparte el código con tus amigos`);
    startSync();updMPHud();
  });
  MP.peer.on('connection',conn=>setupConn(conn));
  MP.peer.on('error',e=>{
    mpStatus(`❌ ${e.type==='unavailable-id'?'ID ocupado, reintentando...':'Error: '+e.type}`,'#ff4455');
    if(e.type==='unavailable-id')setTimeout(hostRoom,400);
  });
}

// JOIN
function joinRoom(code){
  if(MP.peer){MP.peer.destroy();MP.peer=null;}
  mpStatus('⏳ Conectando...');
  MP.peer=new Peer(genCode(),{debug:0});
  MP.isHost=false;
  MP.peer.on('open',id=>{
    MP.myId=id;MP.connected=true;
    const target=code.trim().toUpperCase();
    MP.roomCode=target;
    const conn=MP.peer.connect(target,{reliable:false,serialization:'json'});
    setupConn(conn);
    MP.peer.on('connection',c2=>setupConn(c2));
    startSync();
    mpStatus(`⏳ Conectando a <strong>${target}</strong>...`);
  });
  MP.peer.on('error',e=>{
    const msg=e.type==='peer-unavailable'?'Sala no encontrada. Verifica el código.':'Error: '+e.type;
    mpStatus(`❌ ${msg}`,'#ff4455');
    const err=document.getElementById('joinErr');if(err){err.textContent=msg;err.style.display='block';}
  });
}

