const MP_NAMES=['Axel','Rayo','Sombra','Cobra','Fénix','Lobo','Tigre','Águila','Viper','Ghost'];
let myMPName = MP_NAMES[Math.floor(Math.random()*MP_NAMES.length)] + Math.floor(Math.random()*99);
let myMPColor = [0xff4422,0x22aaff,0xffcc00,0x44ff88,0xff44ff,0xff8844,0x44ffff][Math.floor(Math.random()*7)];

// Sync name input
setTimeout(()=>{
  const inp=document.getElementById('mpNameInp');
  if(inp){inp.value=myMPName;inp.addEventListener('input',()=>{if(inp.value.trim())myMPName=inp.value.trim();});}
},120);

const MP={
  peer:null, myId:null, roomCode:null,
  conns:{},           // peerId → DataConnection
  others:{},          // peerId → {mesh,x,z,ang,tx,tz,tang,wb,name,color,last,nMesh}
  isHost:false, connected:false,
  syncInt:null,
};

function mpStatus(msg,col='#334'){
  const el=document.getElementById('mpTxt');if(el){el.textContent=msg;el.style.color=col;}
  const border=col==='#44ff88'?'#225533':col==='#ff4455'?'#552233':'#1a1a2a';
  const box=document.getElementById('mpStatus');if(box)box.style.borderColor=border;
}
function mpCount(){return 1+Object.keys(MP.others).length;}

// Build remote player mesh
function buildRemote(uid,col,name){
  const g=new THREE.Group();
  const b=new THREE.Mesh(BG(.58,1,.34),M(col));b.position.y=.9;g.add(b);
  const h=new THREE.Mesh(SG(.26,8),M(0xffcc99));h.position.y=1.65;g.add(h);
  const ll2=new THREE.Mesh(BG(.2,.65,.22),M(0x222255));ll2.position.set(-.16,.15,0);g.add(ll2);
  const rl2=ll2.clone();rl2.position.x=.16;g.add(rl2);
  const la2=new THREE.Mesh(BG(.17,.6,.17),M(0xffcc99));la2.position.set(-.41,.88,0);g.add(la2);
  const ra2=la2.clone();ra2.position.x=.41;g.add(ra2);
  // Name tag
  const nc=document.createElement('canvas');nc.width=128;nc.height=28;
  const nx2=nc.getContext('2d');
  nx2.fillStyle='rgba(0,0,0,.75)';nx2.beginPath();nx2.roundRect(0,0,128,28,5);nx2.fill();
  nx2.fillStyle='#fff';nx2.font='bold 12px monospace';nx2.textAlign='center';
  nx2.fillText(name.slice(0,14),64,20);
  const ntex=new THREE.CanvasTexture(nc);
  const nMesh=new THREE.Mesh(new THREE.PlaneGeometry(1.8,.4),new THREE.MeshBasicMaterial({map:ntex,transparent:true,depthTest:false}));
  nMesh.position.y=2.3;g.add(nMesh);
  scene.add(g);
  return {mesh:g,x:0,z:0,ang:0,tx:0,tz:0,tang:0,wb:0,name,color:col,nMesh,last:Date.now()};
}
function removeRemote(uid){
  if(MP.others[uid]){scene.remove(MP.others[uid].mesh);delete MP.others[uid];}
  delete MP.conns[uid];
  updMPHud();
}
function updMPHud(){
  const show=MP.connected;
  document.getElementById('mpHud').style.display=show?'block':'none';
  if(!show) return;

  const n=mpCount();
  // Header count
  const countEl=document.getElementById('mpHudCount');
  if(countEl) countEl.textContent=n+' jugador'+(n!==1?'es':'');

  // Room code
  const codeEl=document.getElementById('mpHudCode');
  if(codeEl) codeEl.textContent=MP.roomCode||'—';

  // Players list
  const listEl=document.getElementById('mpHudPlayers');
  if(listEl){
    // Me
    let html2=`<div style="display:flex;align-items:center;gap:6px;"><span style="width:8px;height:8px;border-radius:50%;background:#4af;display:inline-block;"></span><span style="color:#ccc;font-size:10px;">${myMPName} <span style="color:#666;font-size:9px;">(tú)</span></span></div>`;
    // Others
    Object.values(MP.others).forEach(op=>{
      const col='#'+((op.color||0xff4422).toString(16).padStart(6,'0'));
      html2+=`<div style="display:flex;align-items:center;gap:6px;"><span style="width:8px;height:8px;border-radius:50%;background:${col};display:inline-block;box-shadow:0 0 4px ${col};"></span><span style="color:#ccc;font-size:10px;">${op.name||'Jugador'}</span></div>`;
    });
    listEl.innerHTML=html2;
  }
}

function toggleMPHud(){
  const body=document.getElementById('mpHudBody');
  const arrow=document.getElementById('mpHudArrow');
  if(!body||!arrow) return;
