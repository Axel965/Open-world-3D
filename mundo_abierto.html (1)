<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>OpenWorld GTA</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://unpkg.com/peerjs@1.4.7/dist/peerjs.min.js"></script>
<style>
:root{--g:#f0c040;--gr:#44ff88;--b:#66aaff;--r:#ff3344;--p:#cc66ff;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:#000;overflow:hidden;font-family:'Courier New',monospace;user-select:none;touch-action:none;}
#cv{display:block;width:100vw;height:100vh;}
#ld{position:fixed;inset:0;background:#04040c;z-index:999;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;}
#ldT{color:var(--g);font-size:24px;font-weight:900;letter-spacing:4px;}
#ldS{color:#445;font-size:11px;letter-spacing:2px;}
#ldB{width:200px;height:5px;background:#111;border-radius:3px;overflow:hidden;}
#ldF{height:100%;background:linear-gradient(90deg,#f0c040,#ff6600);width:0;transition:width .25s;}
#mnu{position:fixed;inset:0;z-index:100;display:none;align-items:center;justify-content:center;flex-direction:column;background:radial-gradient(ellipse at 50% 20%,#140a30 0%,#04040c 70%);}
#mBg{position:absolute;inset:0;overflow:hidden;}
.mS{position:absolute;border-radius:50%;background:#fff;animation:tw linear infinite;}
@keyframes tw{0%,100%{opacity:.07}50%{opacity:.9}}
#mLogo{position:relative;text-align:center;margin-bottom:10px;}
#mLogo h1{font-size:clamp(42px,8vw,80px);font-weight:900;letter-spacing:5px;background:linear-gradient(130deg,#f0c040,#ff6600,#ff1155,#aa33ff,#33aaff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 20px rgba(255,100,0,.3));animation:lg 2.8s ease-in-out infinite;}
@keyframes lg{0%,100%{filter:drop-shadow(0 0 20px rgba(255,100,0,.3))}50%{filter:drop-shadow(0 0 40px rgba(255,100,0,.6))}}
.sub{color:#334;font-size:11px;letter-spacing:10px;text-transform:uppercase;-webkit-text-fill-color:#334;}
#mCard{position:relative;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:24px 30px;width:clamp(295px,370px,90vw);backdrop-filter:blur(14px);box-shadow:0 0 80px rgba(100,60,220,.12),inset 0 1px 0 rgba(255,255,255,.05);}
#pRow{display:flex;align-items:center;gap:10px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:9px 12px;margin-bottom:12px;}
#pAv{font-size:26px;}.pNm{color:#ccc;font-size:11px;font-weight:bold;}.pSt2{color:#334;font-size:9px;margin-top:1px;}
.mB{display:flex;align-items:center;gap:10px;width:100%;padding:10px 14px;margin-bottom:6px;border-radius:9px;cursor:pointer;font-family:'Courier New',monospace;font-size:12px;font-weight:bold;border:1px solid;transition:all .14s;letter-spacing:.2px;}
.mB:last-child{margin-bottom:0;}.mB:hover{transform:translateX(4px);filter:brightness(1.25);}
.mB .ic{font-size:18px;min-width:22px;}
.b1{background:linear-gradient(135deg,rgba(240,192,64,.14),rgba(255,100,0,.09));border-color:var(--g);color:var(--g);}
.b2{background:linear-gradient(135deg,rgba(255,70,70,.09),rgba(200,20,20,.06));border-color:var(--r);color:var(--r);}
.b3{background:linear-gradient(135deg,rgba(68,255,136,.07),rgba(0,180,80,.05));border-color:var(--gr);color:var(--gr);}
.b4{background:linear-gradient(135deg,rgba(200,100,255,.09),rgba(130,20,200,.05));border-color:var(--p);color:var(--p);}
.b5{background:linear-gradient(135deg,rgba(255,150,50,.08),rgba(200,90,0,.05));border-color:#ffaa44;color:#ffaa44;}
.b6{background:rgba(255,255,255,.02);border-color:#181818;color:#2a2a2a;}
#hud{display:none;}
#stats{position:fixed;top:10px;left:10px;background:rgba(0,0,0,.8);border:2px solid var(--g);border-radius:9px;padding:7px 11px;color:var(--g);font-size:10px;line-height:2;pointer-events:none;z-index:10;}
#topR{position:fixed;top:10px;right:10px;display:flex;flex-direction:column;align-items:flex-end;gap:4px;z-index:10;pointer-events:none;}
#clk{background:rgba(0,0,0,.8);border:2px solid var(--b);border-radius:9px;padding:5px 12px;color:var(--b);font-size:14px;font-weight:bold;text-align:center;}
#clk small{display:block;font-size:9px;color:#888;}
#mmB{background:rgba(0,0,0,.88);border:2px solid var(--g);border-radius:7px;padding:2px;}
#mm{display:block;border-radius:4px;}
#mmL{text-align:center;color:var(--g);font-size:8px;margin-top:2px;}
#zone{position:fixed;top:62px;left:10px;color:rgba(255,255,255,.5);font-size:9px;pointer-events:none;z-index:10;font-style:italic;}
#xh{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:14px;height:14px;pointer-events:none;z-index:10;}
#xh::before,#xh::after{content:'';position:absolute;background:rgba(255,255,255,.85);}
#xh::before{width:2px;height:100%;left:49%;top:0;}#xh::after{width:100%;height:2px;top:49%;left:0;}
#prompt{position:fixed;bottom:148px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.85);border:1px solid var(--gr);border-radius:7px;padding:4px 14px;color:var(--gr);font-size:11px;display:none;pointer-events:none;z-index:10;}
#msg{position:fixed;top:38%;left:50%;transform:translate(-50%,-50%);background:rgba(0,0,0,.93);border:2px solid var(--g);border-radius:11px;padding:10px 18px;color:#fff;font-size:12px;text-align:center;display:none;max-width:300px;pointer-events:none;z-index:50;white-space:pre-line;}
#msnH{position:fixed;top:50%;left:10px;transform:translateY(-50%);background:rgba(0,0,0,.8);border:2px solid var(--r);border-radius:9px;padding:7px 11px;color:#fff;font-size:10px;max-width:170px;display:none;pointer-events:none;z-index:10;}
#msnH .mt{color:var(--r);font-weight:bold;font-size:11px;margin-bottom:3px;}
#kf{position:fixed;top:64px;left:10px;pointer-events:none;z-index:10;}
.kfi{background:rgba(0,0,0,.7);border-left:3px solid var(--r);padding:2px 8px;color:#fff;font-size:9px;margin-bottom:2px;border-radius:0 4px 4px 0;animation:fo 3s forwards;}
@keyframes fo{0%{opacity:1}70%{opacity:1}100%{opacity:0}}
#wpn{position:fixed;bottom:-4px;right:40px;font-size:58px;line-height:1;pointer-events:none;z-index:10;text-shadow:2px 4px 10px #000;transition:transform .07s;}
#wpn.fire{transform:translateY(-12px) scale(1.1);}
#petD{position:fixed;bottom:0;left:40px;font-size:42px;line-height:1;pointer-events:none;z-index:10;}
#amH{position:fixed;bottom:10px;right:10px;color:rgba(255,255,255,.75);font-size:10px;text-align:right;pointer-events:none;z-index:10;line-height:1.7;}
#hpW{position:fixed;bottom:10px;left:50%;transform:translateX(-50%);pointer-events:none;z-index:10;}
#hpB{width:140px;height:9px;background:#300;border:1px solid #500;border-radius:5px;overflow:hidden;}
#hpF{height:100%;border-radius:5px;transition:width .22s,background .22s;}
#hpT{text-align:center;color:#fff;font-size:9px;margin-top:2px;}
#wanted{position:fixed;top:10px;left:50%;transform:translateX(-50%);display:none;gap:3px;pointer-events:none;z-index:10;}
.wS{font-size:13px;color:#222;}.wS.on{color:#ffcc00;text-shadow:0 0 5px #ffcc00;}
#carHud{position:fixed;bottom:52px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.82);border:1px solid #555;border-radius:7px;padding:4px 13px;color:#fff;font-size:11px;display:none;pointer-events:none;z-index:10;}
#dmgFx{position:fixed;inset:0;background:rgba(255,0,0,0);pointer-events:none;z-index:9;transition:background .12s;}
#jL,#jR{position:fixed;bottom:70px;width:108px;height:108px;z-index:20;touch-action:none;}
#jL{left:10px;}#jR{right:10px;}
.jB{position:absolute;inset:7px;border-radius:50%;background:rgba(255,255,255,.05);border:2px solid rgba(255,255,255,.14);}
.jK{position:absolute;width:34px;height:34px;border-radius:50%;top:calc(50%-17px);left:calc(50%-17px);}
#jKL{background:rgba(240,192,64,.7);border:2px solid var(--g);}
#jKR{background:rgba(100,150,255,.58);border:2px solid var(--b);}
#eBtn{position:fixed;bottom:190px;right:20px;width:46px;height:46px;border-radius:50%;background:rgba(68,255,136,.13);border:2px solid var(--gr);color:var(--gr);font-size:10px;cursor:pointer;z-index:20;display:flex;align-items:center;justify-content:center;flex-direction:column;line-height:1.2;}
#eBtn:active{background:rgba(68,255,136,.35);}
#fBtn{position:fixed;bottom:118px;right:138px;width:43px;height:43px;border-radius:50%;background:rgba(255,40,40,.13);border:2px solid var(--r);color:var(--r);font-size:16px;cursor:pointer;z-index:20;display:flex;align-items:center;justify-content:center;}
#fBtn:active{background:rgba(255,40,40,.35);}
#bBar{position:fixed;bottom:10px;left:50%;transform:translateX(-50%);display:flex;gap:4px;flex-wrap:wrap;justify-content:center;z-index:20;}
.btn{background:rgba(0,0,0,.88);border:2px solid var(--g);color:var(--g);padding:5px 9px;border-radius:6px;cursor:pointer;font-family:'Courier New',monospace;font-size:10px;}
.btn:active{background:var(--g);color:#000;}
.btn.r{border-color:#ff8844;color:#ff8844;}.btn.r:active{background:#ff8844;color:#000;}
.btn.b{border-color:var(--b);color:var(--b);}.btn.b:active{background:var(--b);color:#000;}
.pan{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(3,3,14,.97);border-radius:13px;padding:14px;color:#fff;display:none;min-width:280px;max-width:91vw;max-height:80vh;overflow-y:auto;z-index:60;pointer-events:all;}
#shopP{border:2px solid var(--g);}#jobP{border:2px solid var(--gr);}#npcP{border:2px solid var(--b);}#skinP{border:2px solid var(--p);}#petP{border:2px solid #ffaa44;}#msnP{border:2px solid var(--r);}#intP{border:2px solid var(--g);}
.ph{font-size:12px;font-weight:bold;margin-bottom:8px;}
.tabs{display:flex;gap:3px;margin-bottom:7px;flex-wrap:wrap;}
.tab{background:rgba(255,255,255,.05);border:1px solid #333;color:#777;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:10px;}
.tab.on{background:var(--g);color:#000;border-color:var(--g);}
.irow{display:flex;justify-content:space-between;align-items:center;padding:5px 0;border-bottom:1px solid #111;font-size:10px;gap:5px;}
.irow:last-child{border-bottom:none;}.inn{flex:1;}.ipr{color:var(--g);min-width:56px;text-align:right;}
.ibuy{background:var(--g);color:#000;border:none;padding:3px 8px;border-radius:4px;cursor:pointer;font-size:9px;font-weight:bold;min-width:52px;}
.ibuy:hover:not(:disabled){background:#ffd700;}.ibuy:disabled{background:#111;color:#333;cursor:default;}
.ibuyg{background:var(--gr);color:#000;}.ibuyg:hover:not(:disabled){background:#66ffaa;}
.ibuyr{background:var(--r);color:#fff;}.ibuyr:hover:not(:disabled){background:#ff7788;}
.ibuym{background:var(--p);color:#000;}.ibuym:hover:not(:disabled){background:#dd88ff;}
.ibuyo{background:#ffaa44;color:#000;}.ibuyo:hover:not(:disabled){background:#ffcc66;}
.cbtn{margin-top:8px;width:100%;background:transparent;border:1px solid #222;color:#444;padding:6px;border-radius:5px;cursor:pointer;font-size:10px;}
.cbtn:hover{border-color:var(--g);color:var(--g);}
.nline{background:rgba(255,255,255,.04);border-radius:6px;padding:7px;margin-bottom:7px;font-size:11px;line-height:1.6;color:#bbb;}
.nopt{background:rgba(68,136,255,.09);border:1px solid var(--b);color:var(--b);padding:5px 9px;border-radius:5px;cursor:pointer;font-size:10px;width:100%;margin-bottom:3px;text-align:left;}
.nopt:hover{background:rgba(68,136,255,.22);}
.cG{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;}
.sC,.pC{display:flex;flex-direction:column;align-items:center;background:rgba(255,255,255,.04);border:1px solid #1e1e1e;border-radius:8px;padding:8px 5px;width:76px;}
.sC.eq{border-color:var(--p);}.pC.eq{border-color:#ffaa44;}
.cI{font-size:22px;}.cN{font-size:9px;color:#aaa;margin-top:2px;text-align:center;}.cD{font-size:7px;color:#444;margin-top:1px;text-align:center;}
.msnCard{background:rgba(255,40,40,.05);border:1px solid rgba(255,40,40,.2);border-radius:7px;padding:8px;margin-bottom:6px;}
.msnCard.done{border-color:#44ff88;background:rgba(68,255,136,.04);}
.msnCard.act{border-color:var(--r);background:rgba(255,40,40,.09);}
.mTit{font-size:11px;font-weight:bold;color:var(--r);margin-bottom:2px;}
.msnCard.done .mTit{color:#44ff88;}
.mDesc{font-size:9px;color:#666;line-height:1.5;}.mRew{font-size:9px;color:var(--g);margin-top:3px;}
.iAB{display:block;width:100%;padding:9px 13px;margin-bottom:6px;border-radius:7px;cursor:pointer;font-family:'Courier New',monospace;font-size:11px;font-weight:bold;border:1px solid var(--g);background:rgba(240,192,64,.07);color:var(--g);text-align:left;transition:all .13s;}
.iAB:hover{background:rgba(240,192,64,.18);transform:translateX(3px);}
/* MP name input */
#mpNameRow{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
#mpNameRow span{color:#334;font-size:10px;white-space:nowrap;}
#mpNameInp{flex:1;background:rgba(255,255,255,.05);border:1px solid #222;color:#ccc;padding:5px 9px;border-radius:6px;font-family:monospace;font-size:11px;outline:none;}
</style>
</head>
<body>
<canvas id="cv"></canvas>
<div id="ld"><div id="ldT">OPENWORLD</div><div id="ldS">Cargando ciudad...</div><div id="ldB"><div id="ldF"></div></div></div>
<div id="mnu">
  <div id="mBg"></div>
  <div id="mLogo"><h1>OPENWORLD</h1><div class="sub">Ciudad Sin Límites · GTA Style</div></div>
  <div id="mCard">
    <div id="pRow"><div id="pAv">🧍</div><div><div class="pNm">Jugador</div><div class="pSt2" id="pSt">$1,500 · Nv.1 · 0 kills</div></div></div>
    <div id="mpNameRow"><span>👤 Nombre:</span><input id="mpNameInp" type="text" maxlength="16" placeholder="Tu nombre en MP..."></div>
    <button class="mB b1" id="bPlay"><span class="ic">🎮</span>JUGAR</button>
    <button class="mB b2" id="bMsn2"><span class="ic">📋</span>MISIONES</button>
    <button class="mB b3" id="bShp2"><span class="ic">🛒</span>TIENDA</button>
    <button class="mB b4" id="bSkn2"><span class="ic">👕</span>SKINS</button>
    <button class="mB b5" id="bPet2"><span class="ic">🐾</span>MASCOTAS</button>
    <button class="mB b6" id="bCfg2"><span class="ic">⚙️</span>CONFIGURACIÓN</button>
    <div style="border-top:1px solid rgba(255,255,255,.06);margin:10px 0 8px;"></div>
    <div style="color:#334;font-size:9px;letter-spacing:2px;text-transform:uppercase;margin-bottom:7px;text-align:center;">— MULTIJUGADOR —</div>
    <div style="display:flex;gap:6px;margin-bottom:7px;">
      <button class="mB b1" id="bHost" style="flex:1;padding:9px 10px;font-size:11px;margin:0;"><span class="ic">📡</span>CREAR SALA</button>
      <button class="mB b3" id="bJoin" style="flex:1;padding:9px 10px;font-size:11px;margin:0;"><span class="ic">🔗</span>UNIRSE</button>
    </div>
    <div id="mpStatus" style="background:rgba(0,0,0,.4);border:1px solid #1a1a2a;border-radius:8px;padding:7px 10px;font-size:10px;color:#334;min-height:30px;display:flex;align-items:center;gap:8px;">
      <span id="mpTxt">⚪ Sin conexión · Crea o únete a una sala</span>
    </div>
  </div>
  <div style="position:relative;color:#111;font-size:8px;margin-top:9px;">Joystick izq=mover · Der=cámara · F=disparar · E=entrar</div>
</div>
<!-- JOIN DIALOG -->
<div id="joinDlg" style="position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:200;display:none;align-items:center;justify-content:center;">
  <div style="background:rgba(8,8,22,.98);border:2px solid var(--gr);border-radius:14px;padding:22px;width:290px;max-width:92vw;">
    <div style="color:var(--gr);font-size:14px;font-weight:bold;margin-bottom:4px;">🔗 Unirse a sala</div>
    <div style="color:#445;font-size:10px;margin-bottom:14px;">Ingresa el código que te compartió el host</div>
    <input id="joinId" type="text" maxlength="20" placeholder="Código de sala..." autocomplete="off"
      style="width:100%;background:#0a0a1a;border:1px solid #334;color:#fff;padding:9px 12px;border-radius:7px;font-family:monospace;font-size:13px;outline:none;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;">
    <div id="joinErr" style="color:#ff4455;font-size:10px;margin-bottom:8px;display:none;"></div>
    <div style="display:flex;gap:8px;">
      <button id="joinConfirm" style="flex:1;background:rgba(68,255,136,.12);border:1px solid var(--gr);color:var(--gr);padding:9px;border-radius:7px;cursor:pointer;font-family:monospace;font-size:11px;font-weight:bold;">✅ Conectar</button>
      <button id="joinCancel" style="flex:1;background:rgba(255,255,255,.04);border:1px solid #222;color:#555;padding:9px;border-radius:7px;cursor:pointer;font-family:monospace;font-size:11px;">Cancelar</button>
    </div>
  </div>
</div>

<!-- MP HUD (shown while in-game) -->
<div id="mpHud" style="position:fixed;top:10px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,.88);border:2px solid var(--gr);border-radius:11px;padding:0;display:none;z-index:20;min-width:200px;max-width:260px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.5);">
  <!-- Header bar — always visible, click to toggle expand -->
  <div id="mpHudBar" style="display:flex;align-items:center;justify-content:space-between;padding:6px 12px;cursor:pointer;gap:8px;" onclick="toggleMPHud()">
    <div style="display:flex;align-items:center;gap:7px;">
      <span id="mpDot" style="width:8px;height:8px;border-radius:50%;background:#44ff88;display:inline-block;box-shadow:0 0 5px #44ff88;"></span>
      <span style="color:var(--gr);font-size:11px;font-weight:bold;">👥 MULTIJUGADOR</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px;">
      <span id="mpHudCount" style="color:#fff;font-size:10px;background:rgba(68,255,136,.18);border:1px solid var(--gr);border-radius:4px;padding:1px 6px;">1 jugador</span>
      <span id="mpHudArrow" style="color:var(--gr);font-size:10px;">▼</span>
    </div>
  </div>
  <!-- Expandable body -->
  <div id="mpHudBody" style="display:none;border-top:1px solid rgba(68,255,136,.2);padding:10px 12px;">
    <!-- Room code display -->
    <div style="margin-bottom:8px;">
      <div style="color:#556;font-size:9px;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Código de sala</div>
      <div style="display:flex;align-items:center;gap:6px;">
        <div id="mpHudCode" style="flex:1;background:rgba(240,192,64,.1);border:1px solid var(--g);border-radius:6px;padding:5px 10px;color:var(--g);font-size:14px;font-weight:900;letter-spacing:3px;text-align:center;">—</div>
        <button onclick="copyRoomCode()" style="background:rgba(240,192,64,.15);border:1px solid var(--g);color:var(--g);padding:5px 8px;border-radius:6px;cursor:pointer;font-size:11px;" title="Copiar código">📋</button>
      </div>
    </div>
    <!-- Players list -->
    <div style="margin-bottom:8px;">
      <div style="color:#556;font-size:9px;text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Jugadores</div>
      <div id="mpHudPlayers" style="display:flex;flex-direction:column;gap:3px;"></div>
    </div>
    <!-- Actions -->
    <div style="display:flex;gap:5px;">
      <button onclick="inviteFriend()" style="flex:1;background:rgba(68,255,136,.1);border:1px solid var(--gr);color:var(--gr);padding:5px 0;border-radius:6px;cursor:pointer;font-family:monospace;font-size:10px;">🔗 Invitar</button>
      <button onclick="disconnectMP()" style="flex:1;background:rgba(255,50,50,.1);border:1px solid var(--r);color:var(--r);padding:5px 0;border-radius:6px;cursor:pointer;font-family:monospace;font-size:10px;">🔌 Salir</button>
    </div>
  </div>
</div>

<!-- Join dialog (keep existing) -->

<div id="hud">
  <div id="stats">💰 $<span id="sm">1500</span><br>💎 <span id="sd">0</span><br>⭐ Nv.<span id="slv">1</span><br>💀 <span id="skl">0</span></div>
  <div id="topR">
    <div id="clk"><span id="tt">08:00</span><small id="td">Lunes</small></div>
    <div id="mmB"><canvas id="mm" width="120" height="120"></canvas><div id="mmL">🗺 Mapa</div></div>
